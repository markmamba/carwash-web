# carwash-web environment variables
# Copy to .env.local for local development

# Rails API base URL (no trailing slash)
VITE_API_CARWASH_URL=http://localhost:3000

# Environment label: development | qa | production
VITE_APP_ENV=development

# Optional: git commit SHA shown in admin footer (set in CI/deploy)
# VITE_COMMIT_SHA=
